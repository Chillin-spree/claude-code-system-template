{
  "permissions": {
    "allow": [
      "Bash(npx prettier --write:*)",
      "Bash(npm run lint:*)",
      "Bash(node --test:*)",
      "Bash(python3 -m http.server:*)"
    ],
    "ask": ["Bash(git commit:*)", "Bash(git push:*)"],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --no-verify:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard-secret-paths.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/guard-git.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/format-on-edit.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f package.json ] && [ -d node_modules ]; then npm run lint || exit 2; fi"
          }
        ]
      }
    ]
  }
}
